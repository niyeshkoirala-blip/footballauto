# ─── REQUIRED ────────────────────────────────────────────────────────────────
# Your normal Facebook login credentials (no developer account needed)
FB_EMAIL=your_facebook_email@gmail.com
FB_PASSWORD=your_facebook_password

# The full URL of your Facebook Page (the page you want to post to)
# Example: https://www.facebook.com/MyFootballPage
FB_PAGE_URL=https://www.facebook.com/YourPageName

# Pexels free image API (sign up free at https://www.pexels.com/api/)
PEXELS_API_KEY=your_pexels_api_key

# ─── OPTIONAL ─────────────────────────────────────────────────────────────────
# Groq free AI API for smarter captions (sign up free at https://console.groq.com)
# If left blank, captions are taken directly from the RSS feed text — still works fine.
GROQ_API_KEY=

# ─── SETTINGS ─────────────────────────────────────────────────────────────────
# Your Facebook page display name shown as branding on the image
PAGE_NAME=FOOTBALL NEWS

# How many posts to publish per run (default: 1)
POSTS_PER_RUN=1

# Breaking-news threshold (0–100). A story must score at or above this to trigger
# an immediate post during the every-15-min polling runs.
# Scheduled runs (08:00 / 14:00 / 20:00 UTC) always post regardless of score.
# Lower = more sensitive (more posts). Raise if you get too many minor stories.
BREAKING_THRESHOLD=55

# Random delay between consecutive posts in the same run (seconds)
# Randomness avoids predictable bot patterns that Facebook flags
POST_DELAY_MIN=25
POST_DELAY_MAX=35
